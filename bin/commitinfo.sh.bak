#!/bin/sh


sed \
	-e "/^:global CommitId/c :global CommitId \"${COMMITID:-unknown}\";" \
	-e "/^:global CommitInfo/c :global CommitInfo \"${COMMITINFO:-unknown}\";" \
	< "${1}"

GitDir=`pwd`
binDir=$GitDir"/bin/"
htmlDir=$GitDir"/html/"

#cd $htmlDir

set -e



cd $GitDir

git add .

if git commit -m "Backup for ${GitDir} sucessfully created at $(date '+%b %d %T')."; then

    if git push origin main; then
#        save_log "${log_msg}"
	exit 0
    else
#        save_log "${log_msg}"
	exit 1
    fi

else

exit 1
fi

